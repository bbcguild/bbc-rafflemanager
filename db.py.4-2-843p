@with_cursor_boolean
def set_cur_raffle_info (cur, guild_id, raffle_info):
    cur_id = gcri()
    if not cur_id:
        return False

    r = raffle_info

    cur.execute("PRAGMA table_info(raffles)")
    columns = [row[1] for row in cur.fetchall()]

    if "raffle_title" in columns and "raffle_status" in columns:
        cur.execute("UPDATE raffles SET raffle_guild=?, raffle_guild_num=?, raffle_time=?, raffle_ticket_cost=?, raffle_closed=?, raffle_notes=?, raffle_title=?, raffle_status=? WHERE raffle_id=?", (r["raffle_guild"], r["raffle_guild_num"], r["raffle_time"], r["raffle_ticket_cost"], r["raffle_closed"], r["raffle_notes"], r.get("raffle_title", ""), r.get("raffle_status", "LIVE"), cur_id))
    else:
        cur.execute("UPDATE raffles SET raffle_guild=?, raffle_guild_num=?, raffle_time=?, raffle_ticket_cost=?, raffle_closed=?, raffle_notes=? WHERE raffle_id=?", (r["raffle_guild"], r["raffle_guild_num"], r["raffle_time"], r["raffle_ticket_cost"], r["raffle_closed"], r["raffle_notes"], cur_id))

