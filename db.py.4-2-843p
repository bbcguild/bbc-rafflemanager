    cur_id = gcri()
    if not cur_id:
        return False

    cur.execute("UPDATE raffles SET raffle_closed=1 WHERE raffle_id=?", (cur_id, ))

@with_cursor_boolean
def open_new_raffle (cur, guild_id):
    cur.execute("PRAGMA table_info(raffles)")
    columns = [row[1] for row in cur.fetchall()]

    if "raffle_title" in columns and "raffle_status" in columns:
        cur.execute("INSERT INTO raffles (raffle_guild, raffle_guild_num, raffle_time, raffle_ticket_cost, raffle_closed, raffle_notes, raffle_title, raffle_status) VALUES (?, 0, 'Fill this in!', '1000g', 0, '', '', 'LIVE')", (guild_id, ))
    else:
        cur.execute("INSERT INTO raffles VALUES (null, ?, 0, 'Fill this in!', '1000g', 0, '')", (guild_id, ))

